// leetcode # 11 : 11. Container With Most Water
Medium
You are given an integer array height of length n. There are n vertical lines drawn such that the two endpoints of the ith line are (i, 0) and (i, height[i]).
Find two lines that together with the x-axis form a container, such that the container contains the most water.
Return the maximum amount of water a container can store.
Notice that you may not slant the container.

Input: height = [1,8,6,2,5,4,8,3,7]
Output: 49
Explanation: The above vertical lines are represented by array [1,8,6,2,5,4,8,3,7]. In this case, the max area of water (blue section) the container can contain is 49.
Example 2:

Input: height = [1,1]
Output: 1

Constraints:

n == height.length
2 <= n <= 105
0 <= height[i] <= 104

// METHOD 1: ( BRUTE FORCE)

class Solution {
public:
    int maxArea(vector<int>& height) {
         
         int left = 0;
         int right = 0;
         int currar = 0;
         int maxar = 0;

         for(left = 0; left < height.size(); left++){
            for(right = left; right < height.size(); right++){
                if(height[left] < height[right]){
                    currar = (right - left ) * height[left];
                }
                else{
                    currar = (right - left )  * height[right];
                }

                if(currar > maxar){
                    maxar = currar;
                }
            }
         }
         return maxar;
    }
};


// MOTHOD 2 : ( two pointer technique) 

class Solution {
public:
    int maxArea(vector<int>& height) {
         
         int left = 0;
         int right = height.size() - 1;
         int currar = 0;
         int maxar = 0;

        while(left < right){
           currar = (right - left) * min(height[left],height[right]);
           maxar  = max(currar,maxar);

           if(height[left] < height[right]){
                 left ++ ;
           }
           else{
            right --;
           }
        }
        return maxar;
    }
};































